@Library("test.groovy")_
pipeline {
  agent any
  tools {
    jdk "jdk21"
    maven "maven"
  }
  parameters {
    //string (name: "env", defaultValue: "main", description: "using main branch as default")
    choice (name: "env", choices: ["main", "dev", "qa"])
    booleanParam (name: "Deploy", defaultValue: false)
  }
  stages {
    stage ("git clone") {
      steps {
        git branch: params.env, url: 'https://github.com/BhanuBilla24/bhanu1.git'
      } 
    }
    stage ("test") {
      steps {
        script {
          test(params.env)
        }
      }
    }
    stage ("Deploy") {
      when {
        expression {params.env}
      }
      steps {
        script {
          echo "deploying"
        }
      }
    }
  }
}
